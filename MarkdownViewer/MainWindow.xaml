<Window x:Class="MarkdownViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Markdown Viewer"
        Width="1280"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="8"
                BorderBrush="#D9D9D9"
                BorderThickness="0,0,0,1"
                Background="#F6F7F8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <ToggleButton x:Name="HistoryToggleButton"
                                  Width="32"
                                  Height="32"
                                  Margin="0,0,8,0"
                                  IsChecked="True"
                                  Click="HistoryToggleButton_Click"
                                  ToolTip="履歴一覧の表示/非表示">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE700;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </ToggleButton>

                    <Button x:Name="OpenFileButton"
                            Width="32"
                            Height="32"
                            Click="OpenFileButton_Click"
                            ToolTip="ファイル選択">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE8B7;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <TextBlock x:Name="PathTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Stretch"
                           TextAlignment="Center"
                           Margin="8,0,8,0"
                           TextTrimming="CharacterEllipsis"
                           FontSize="13"
                           Foreground="#444" />

                <Button x:Name="ReloadButton"
                        Grid.Column="2"
                        Width="32"
                        Height="32"
                        Click="ReloadButton_Click"
                        ToolTip="再読み込み">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Text="&#xE72C;"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HistoryColumn"
                                  Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#D9D9D9"
                    BorderThickness="0,0,1,0"
                    Background="#FCFCFC">
                <ListBox x:Name="HistoryListBox"
                         BorderThickness="0"
                         SelectionChanged="HistoryListBox_SelectionChanged"
                         DisplayMemberPath="DisplayName" />
            </Border>

            <wv2:WebView2 x:Name="MarkdownWebView"
                          Grid.Column="1" />
        </Grid>
    </Grid>
</Window>
